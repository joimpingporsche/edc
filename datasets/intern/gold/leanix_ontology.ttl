@prefix dct: <http://purl.org/dc/terms/> .
@prefix leanix: <https://example.org/ont/leanix#> .
@prefix lxc: <https://example.org/ont/leanix/lifecycle#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/ont/leanix>
    rdf:type owl:Ontology ;
    dct:title "LeanIX Enterprise Architecture Ontology"@en ;
    dct:description "Core classes and properties from LeanIX metamodel."@en ;
    owl:versionInfo "v0.1.0" .


#################################################################
#    Classes
#################################################################

###  https://example.org/ont/leanix#LXO0001

leanix:LXO0001 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0031 , leanix:LXO0059 ;
    rdfs:comment "Architecture Decision Records (ADR): collection of decision artefacts capturing architectural choices and their rationale.@en"@en ;
    rdfs:label "ADR@en"@en .

###  https://example.org/ont/leanix#LXO0006

leanix:LXO0006 rdf:type owl:Class ;
    rdfs:comment "Strategic layer defining objectives, initiatives and transformation direction.@en"@en ;
    rdfs:label "Architecture Vision@en"@en .

###  https://example.org/ont/leanix#LXO0007

leanix:LXO0007 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0006 , leanix:LXO0059 ;
    rdfs:comment "Objectives serve as clear targets that provide direction and focus for activities. (source LeanIX)@en"@en ;
    rdfs:label "Objective@en"@en .

###  https://example.org/ont/leanix#LXO0008

leanix:LXO0008 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0006 ;
    rdfs:comment "Structured endeavor aimed at driving change or improvement (source LeanIX).@en"@en ;
    rdfs:label "Initiative@en"@en .

###  https://example.org/ont/leanix#LXO0009

leanix:LXO0009 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0006 ;
    rdfs:comment "Planned architectural or product evolution artifact (distinct from lifecycle state usage).@en"@en ;
    rdfs:label "Plan@en"@en .

###  https://example.org/ont/leanix#LXO0010

leanix:LXO0010 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0006 ;
    rdfs:comment "Time-phased sequence of planned architectural or solution milestones.@en"@en ;
    rdfs:label "Roadmap@en"@en .

###  https://example.org/ont/leanix#LXO0011

leanix:LXO0011 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0006 , leanix:LXO0059 ;
    rdfs:comment "Temporary organization established to deliver a defined architectural change.@en"@en ;
    rdfs:label "Project@en"@en .

###  https://example.org/ont/leanix#LXO0012

leanix:LXO0012 rdf:type owl:Class ;
    rdfs:comment "Structured framework for processes, capabilities and IT alignment. (source LeanIX)@en"@en ;
    rdfs:label "Business Architecture@en"@en .

###  https://example.org/ont/leanix#LXO0013

leanix:LXO0013 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0012 ;
    rdfs:comment "Container for architecture elements enabling hierarchy and ownership analysis. (source LeanIX)@en"@en ;
    rdfs:label "Organization@en"@en .

###  https://example.org/ont/leanix#LXO0014

leanix:LXO0014 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0012 , leanix:LXO0059 ;
    rdfs:comment "Abstract representation of business ability independent of structure or technology. (source LeanIX)@en"@en ;
    rdfs:label "Business Capability@en"@en .

###  https://example.org/ont/leanix#LXO0015

leanix:LXO0015 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0014 ;
    rdfs:comment "Group/category abstraction bundling related business capabilities.@en"@en ;
    rdfs:label "Capability Category@en"@en .

###  https://example.org/ont/leanix#LXO0016

leanix:LXO0016 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0014 ;
    rdfs:comment "Finer-grained capability element refining a parent business capability.@en"@en ;
    rdfs:label "Sub Capability@en"@en .

###  https://example.org/ont/leanix#LXO0017

leanix:LXO0017 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0012 , leanix:LXO0059 ;
    rdfs:comment "Structured set of activities achieving defined business goals. (source LeanIX)@en"@en ;
    rdfs:label "Process@en"@en .

###  https://example.org/ont/leanix#LXO0018

leanix:LXO0018 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0012 ;
    rdfs:comment "Discrete unit of business functionality accessible via defined interfaces. (source LeanIX)@en"@en ;
    rdfs:label "Business Service@en"@en .

###  https://example.org/ont/leanix#LXO0019

leanix:LXO0019 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0012 ;
