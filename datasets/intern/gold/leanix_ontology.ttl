###  https://example.org/ont/leanix#LXO0020

leanix:LXO0020 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0012 , leanix:LXO0021 ;
    rdfs:comment "Business-relevant information entity used in processes and applications. (no explicit description found; placeholder)@en"@en ;
    rdfs:label "Information Object@en"@en .

###  https://example.org/ont/leanix#LXO0021

leanix:LXO0021 rdf:type owl:Class ;
    rdfs:comment "Central layer mapping implementation of business capabilities via applications & data.@en"@en ;
    rdfs:label "Information Systems Architecture@en"@en .

###  https://example.org/ont/leanix#LXO0022

leanix:LXO0022 rdf:type owl:Class ;
    rdfs:subClassOf leanix:LXO0021 ;
