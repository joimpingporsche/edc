###  https://example.org/ont/leanix#LXO0059

leanix:LXO0059 rdf:type owl:Class ;
    rdfs:comment "Abstract superclass for all LeanIX fact sheet types used in this Ontology.@en"@en ;
    rdfs:label "Fact Sheet@en"@en .

#################################################################
#    Object Properties
#################################################################

###  https://example.org/ont/leanix#relToChild

leanix:relToChild rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:label "relToChild"@en ;
    rdfs:comment "Hierarchical child relation between Fact Sheets (must stay within same Fact Sheet type)."@en .

###  https://example.org/ont/leanix#relToParent

leanix:relToParent rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:label "relToParent"@en ;
    rdfs:comment "Hierarchical parent relation between Fact Sheets (must stay within same Fact Sheet type)."@en .

###  https://example.org/ont/leanix#relToPredecessor

leanix:relToPredecessor rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:label "relToPredecessor"@en ;
    rdfs:comment "Versioning/lineage predecessor within the same Fact Sheet type."@en .

###  https://example.org/ont/leanix#relToSuccessor

leanix:relToSuccessor rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:label "relToSuccessor"@en ;
    rdfs:comment "Versioning/lineage successor within the same Fact Sheet type."@en .

###  https://example.org/ont/leanix#relToRequires

leanix:relToRequires rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:label "relToRequires"@en ;
    rdfs:comment "Dependency: the subject requires the object (any Fact Sheet type allowed)."@en .

###  https://example.org/ont/leanix#relToRequiredBy

leanix:relToRequiredBy rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( leanix:LXO0001 leanix:LXO0007 leanix:LXO0011 leanix:LXO0014 leanix:LXO0017 leanix:LXO0025 leanix:LXO0032 leanix:LXO0040 leanix:LXO0055 leanix:LXO0059 leanix:LXO0059 ) ] ;
    rdfs:label "relToRequiredBy"@en ;
    rdfs:comment "Reverse dependency: the subject is required by the object (any Fact Sheet type allowed)."@en .

